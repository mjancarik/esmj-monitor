{
  "compilerOptions": {
    "target": "es2022",
    "module": "Node16",
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "noImplicitAny": true,
    "types": ["node"],
    "resolvePackageJsonExports": false
  },
  "include": ["src/**/*"]
}